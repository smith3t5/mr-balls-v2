# Environment Variables Template# Copy this to .env.local for local development

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_DATABASE_ID=your_database_id_here

# The Odds API (get from https://the-odds-api.com/)
ODDS_API_KEY=your_odds_api_key_here

# NFC Tag Secret (any random string for authentication)
NFC_TAG_SECRET=your_secret_tag_here

# Session Secret (random secure string for JWT signing)
SESSION_SECRET=your_session_secret_here

# Optional: For development
NEXT_PUBLIC_API_URL=http://localhost:3000
